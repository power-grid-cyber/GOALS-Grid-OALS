! ===========================================================================
!  ieee13_linecodes.dss
!  Overhead line impedance configurations for the IEEE 13-bus feeder.
!
!  All values in ohms/mile (positive sequence, balanced equivalent).
!  Derived from the EPRI IEEE 13-bus test feeder documentation.
!
!  Conversion to simulation per-unit:
!    Z_base = kV^2 / MVA = 4.16^2 / 5.0 = 3.4611 ohm
!    Z_pu   = Z_ohm_per_mile * length_miles / Z_base
!
!  Configurations used in this feeder:
!    601  main trunk (heavy loading)    R=0.3465, X=1.0179 ohm/mi
!    602  sub-laterals                  R=0.7526, X=1.1804 ohm/mi
!    603  light laterals               R=1.3294, X=1.3471 ohm/mi
!    604  spur to 684                  R=1.3238, X=1.3569 ohm/mi
!    605  short spur to 611            R=1.3292, X=1.3475 ohm/mi
!    606  underground to 675           R=0.7982, X=0.4463 ohm/mi
!    607  spur to 652                  R=1.3425, X=0.5124 ohm/mi
! ===========================================================================

! ---------------------------------------------------------------------------
!  Config 601 — main trunk overhead, 336.4 kcmil ACSR
!  Used on: 650-632, 632-671, 671-680
! ---------------------------------------------------------------------------
New LineCode.601
~ nphases=3
~ R1=0.3465  X1=1.0179
~ R0=1.3368  X0=1.3343
~ C1=11.1553 C0=5.1207
~ Units=mi

! ---------------------------------------------------------------------------
!  Config 602 — lateral overhead, 4/0 ACSR
!  Used on: 632-633
! ---------------------------------------------------------------------------
New LineCode.602
~ nphases=3
~ R1=0.7526  X1=1.1804
~ R0=1.3294  X0=1.3471
~ C1=10.4054 C0=4.8940
~ Units=mi

! ---------------------------------------------------------------------------
!  Config 603 — light lateral, 1/0 ACSR
!  Used on: 632-645, 645-646
! ---------------------------------------------------------------------------
New LineCode.603
~ nphases=2
~ R1=1.3294  X1=1.3471
~ R0=2.0066  X0=1.5849
~ C1=9.6243  C0=4.2742
~ Units=mi

! ---------------------------------------------------------------------------
!  Config 604 — spur to 684, 1/0 ACSR (2-wire)
!  Used on: 650-684
! ---------------------------------------------------------------------------
New LineCode.604
~ nphases=2
~ R1=1.3238  X1=1.3569
~ R0=2.0522  X0=1.6091
~ C1=9.6243  C0=4.2742
~ Units=mi

! ---------------------------------------------------------------------------
!  Config 605 — single-phase spur, 1/0 ACSR
!  Used on: 684-611
! ---------------------------------------------------------------------------
New LineCode.605
~ nphases=1
~ R1=1.3292  X1=1.3475
~ R0=1.3292  X0=1.3475
~ C1=9.6382  C0=9.6382
~ Units=mi

! ---------------------------------------------------------------------------
!  Config 606 — underground concentric neutral, 250 kcmil AA
!  Used on: 692-675
! ---------------------------------------------------------------------------
New LineCode.606
~ nphases=3
~ R1=0.7982  X1=0.4463
~ R0=2.3933  X0=1.3390
~ C1=153.354 C0=153.354
~ Units=mi

! ---------------------------------------------------------------------------
!  Config 607 — single-phase underground, 1/0 AA
!  Used on: 684-652
! ---------------------------------------------------------------------------
New LineCode.607
~ nphases=1
~ R1=1.3425  X1=0.5124
~ R0=1.3425  X0=0.5124
~ C1=236.083 C0=236.083
~ Units=mi
